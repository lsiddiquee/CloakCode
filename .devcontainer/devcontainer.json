{
  // CloakCode dev container.
  // Pure TypeScript/Node monorepo: VS Code extension + local bridge + React PWA client.
  "name": "CloakCode",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:24-bookworm",
  // Fixed workspace location regardless of the host folder name. This keeps every
  // absolute path (scripts, tasks, docs) stable no matter what the source folder is called.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/cloakcode,type=bind",
  "workspaceFolder": "/workspaces/cloakcode",
  // Grab the host IP from the host before building the container this is needed specially when running in WSL,
  // we use this to connect to the gateway which can be running in the WSL/Host.
  "initializeCommand": "echo \"HOST_IP=$(hostname -I | awk '{print $1}')\" > ${localWorkspaceFolder}/.devcontainer/.devcontainer.env",
  // Inject the environment file into the running container
  "runArgs": [
    "--env-file",
    "${localWorkspaceFolder}/.devcontainer/.devcontainer.env"
  ],
  "features": {
    // gh CLI is handy for release/packaging workflows; kept lean otherwise.
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    // Python 3.12 for the research/observer tooling under research/ (Poetry-managed).
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    // go-task: the Taskfile.yml runner (`task --list`) for the build/package/run
    // flows — one source of truth shared with WSL/host and CI.
    "ghcr.io/devcontainers-extra/features/go-task:1": {}
  },
  // Persisted cache volume: survives rebuilds. bash history + npm/pnpm stores +
  // corepack + Playwright browsers all live here (see remoteEnv below).
  "mounts": [
    "source=devcontainer-cache-cloakcode,target=/.devcontainercache,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.extension-test-runner",
        "EditorConfig.EditorConfig",
        "ms-python.python",
        "charliermarsh.ruff"
      ],
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      }
    }
  },
  // 7801 = local bridge; 5280 = Vite PWA dev; 7900 = dev gateway (task gateway:dev);
  // 5285 = UI playground (task playground). See docs/03-architecture.md / docs/07.
  "forwardPorts": [
    7801,
    5280,
    7900,
    5285
  ],
  "portsAttributes": {
    "7801": {
      "label": "CloakCode Bridge",
      "onAutoForward": "silent"
    },
    "5280": {
      "label": "CloakCode PWA (Vite)",
      "onAutoForward": "notify"
    },
    "7900": {
      "label": "CloakCode Gateway (dev)",
      "onAutoForward": "silent"
    },
    "5285": {
      "label": "CloakCode UI Playground (Vite)",
      "onAutoForward": "notify"
    }
  },
  // Persisted-cache wiring. The named volume (mounted at /.devcontainercache) survives
  // rebuilds; point bash history + package-manager stores at it so rebuilds stay warm.
  "remoteEnv": {
    "PROMPT_COMMAND": "history -a",
    "HISTFILE": "/.devcontainercache/.bash_history",
    "NPM_CONFIG_CACHE": "/.devcontainercache/npm-cache",
    "PNPM_HOME": "/.devcontainercache/pnpm",
    "PNPM_STORE_DIR": "/.devcontainercache/pnpm-store",
    "COREPACK_HOME": "/.devcontainercache/corepack",
    "PLAYWRIGHT_BROWSERS_PATH": "/.devcontainercache/ms-playwright",
    "PIP_CACHE_DIR": "/.devcontainercache/pip-cache",
    "POETRY_CACHE_DIR": "/.devcontainercache/poetry-cache",
    "PRE_COMMIT_HOME": "/.devcontainercache/pre-commit"
  },
  "remoteUser": "node",
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}
