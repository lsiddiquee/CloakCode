# Dependencies
node_modules/
.pnpm-store/

# Python
.venv/
__pycache__/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Build output
dist/
out/
*.tsbuildinfo

# VS Code extension packaging / testing
*.vsix
.vscode-test/

# Env / secrets — never commit
.env
.env.*
!.env.example

# npm/pnpm registry config is ENV-SPECIFIC (e.g. an internal supply-chain proxy).
# Keep it in your user ~/.npmrc, never in the repo — a committed registry breaks
# every contributor who can't reach it. The lockfile stays registry-portable via
# the `pnpm-lock-portable` pre-commit hook.
.npmrc

# Logs
*.log

# OS
.DS_Store
Thumbs.db

.local/

# Local hook probe (Copilot reads .github/hooks/*.json). Keep the throwaway
# probe config out of git; the real CloakCode hook file ships intentionally.
.github/hooks/cloakcode-probe.json

# Generated env file while building devcontainer; not needed in git.
.devcontainer/.devcontainer.env
