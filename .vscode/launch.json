{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CloakCode Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/extension/dist/**/*.cjs"
      ],
      "env": {
        "CLOAKCODE_PORT": "7803",
        "CLOAKCODE_DIAG_FILE": "${workspaceFolder}/.local/cloakcode-diagnostics.txt"
      },
      "preLaunchTask": "bundle-extension"
    }
  ]
}
