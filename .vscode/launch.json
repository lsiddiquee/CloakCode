{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CloakCode Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/extension/dist/**/*.cjs"
      ],
      "env": {
        "CLOAKCODE_GATEWAY_PORT": "7803",
        "CLOAKCODE_DIAG_FILE": "${workspaceFolder}/.local/cloakcode-diagnostics.txt",
        // The devcontainer's initializeCommand writes HOST_IP (the WSL/host IP)
        // into the container env; connect F5 straight to a gateway on the host at
        // ws://<HOST_IP>:7900. A hostless URL (unset HOST_IP -> `ws://:7900`) is
        // ignored, falling back to the embedded bridge.
        "CLOAKCODE_GATEWAY_URL": "ws://${env:HOST_IP}:7900"
      },
      "preLaunchTask": "bundle-extension"
    }
  ]
}
