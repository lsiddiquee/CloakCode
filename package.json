{
  "name": "cloakcode",
  "version": "0.1.2",
  "private": true,
  "description": "Local-to-remote bridge to observe and drive GitHub Copilot from a phone/desktop with zero code-sync.",
  "repository": {
    "type": "git",
    "url": "https://github.com/lsiddiquee/CloakCode.git"
  },
  "homepage": "https://github.com/lsiddiquee/CloakCode#readme",
  "bugs": {
    "url": "https://github.com/lsiddiquee/CloakCode/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "release": "node scripts/release.mjs",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0"
  }
}
