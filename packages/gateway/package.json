{
  "name": "@cloakcode/gateway",
  "version": "0.2.2",
  "private": true,
  "description": "Standalone CloakCode gateway — the run-it-yourself hub that serves the PWA and multiplexes phone (operator) + extension (provider) connections. NO vscode import.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/lsiddiquee/CloakCode.git"
  },
  "homepage": "https://github.com/lsiddiquee/CloakCode#readme",
  "bugs": {
    "url": "https://github.com/lsiddiquee/CloakCode/issues"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node scripts/bundle.mjs",
    "assemble": "bash scripts/assemble-gateway.sh",
    "pack:npm": "pnpm assemble && node scripts/pack-npm.mjs",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cloakcode/protocol": "workspace:*",
    "otpauth": "^9.5.1",
    "qrcode-generator": "^2.0.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.5.12",
    "esbuild": "0.25.12",
    "typescript": "^5.6.0",
    "vitest": "4.1.10"
  }
}
